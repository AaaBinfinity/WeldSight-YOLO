# Copy this file to .env and replace the placeholders.
# Never commit the real .env file.

MOONSHOT_API_KEY=api_key
KIMI_VISION_MODEL=kimi-k3
KIMI_FALLBACK_MODELS=moonshot-v1-32k-vision-preview,kimi-k2.6
KIMI_REVIEW_ENABLED=true
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_TIMEOUT_SECONDS=60
KIMI_MAX_RETRIES=2
KIMI_RETRY_BASE_SECONDS=1

# Optional application settings
YOLO_MODEL_PATH=v-app/best_v8.pt
CONF_THRESH=0.25
CAMERA_DEFAULT_INDEX=0
VIDEO_MAX_PROGRESS_CACHE=30
FLASK_SECRET_KEY=replace_with_a_random_secret
